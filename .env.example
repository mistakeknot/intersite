# intersite — Environment Variables
# Copy this to .env and fill in your values.

# ── Site Identity ──
INTERSITE_SITE_NAME="My Portfolio"
INTERSITE_SITE_SHORT=Portfolio
INTERSITE_SITE_URL=https://example.com
INTERSITE_SITE_DESCRIPTION="Project and experiment showcase"
INTERSITE_NAV_BRAND="My Portfolio"
INTERSITE_FOOTER_BRAND="My Portfolio"
INTERSITE_CONTACT_EMAIL=

# ── Content Directory (absolute path, or empty for built-in examples) ──
INTERSITE_CONTENT_DIR=

# ── Auth (Clerk) ──
# Comma-separated GitHub usernames allowed to access /admin
INTERSITE_AUTH_USERNAMES=
# Comma-separated emails allowed to access /admin
INTERSITE_AUTH_EMAILS=

# ── Clerk Keys ──
PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
PUBLIC_CLERK_SIGN_IN_URL=/sign-in
