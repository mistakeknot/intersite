---
import graphData from '../data/graph.json';
---
<div class="relative">
  <div class="flex gap-2 mb-4">
    <button data-lens="domain" class="lens-btn active text-xs font-mono px-3 py-1 rounded border border-[var(--color-border)] text-[var(--color-text-muted)] hover:text-[var(--color-text)] hover:border-[var(--color-accent)] transition-colors">domain</button>
    <button data-lens="theme" class="lens-btn text-xs font-mono px-3 py-1 rounded border border-[var(--color-border)] text-[var(--color-text-muted)] hover:text-[var(--color-text)] hover:border-[var(--color-accent)] transition-colors">theme</button>
    <button data-lens="status" class="lens-btn text-xs font-mono px-3 py-1 rounded border border-[var(--color-border)] text-[var(--color-text-muted)] hover:text-[var(--color-text)] hover:border-[var(--color-accent)] transition-colors">status</button>
  </div>
  <div id="graph-svg-container" class="border border-[var(--color-border)] rounded-lg bg-[var(--color-surface)] overflow-hidden" style="aspect-ratio: 16/9;">
  </div>
  <div id="graph-tooltip" class="hidden absolute pointer-events-none bg-[var(--color-bg)] border border-[var(--color-border)] rounded-lg px-3 py-2 text-xs font-mono z-10">
  </div>
</div>

<script data-graph={JSON.stringify(graphData)} is:inline>
(function() {
  const script = document.querySelector('script[data-graph]');
  const data = JSON.parse(script.getAttribute('data-graph'));

  const container = document.getElementById('graph-svg-container');
  const tooltip = document.getElementById('graph-tooltip');
  const width = container.clientWidth;
  const height = container.clientHeight || width * 9 / 16;

  // Color palettes
  const domainColors = {
    'autonomous-development': '#3b82f6',
    'editorial-tooling': '#8b5cf6',
    'collaborative-intelligence': '#06b6d4',
    'generative-games': '#f59e0b',
    'prediction-markets': '#10b981',
    'generative-media': '#ec4899',
    'competitive-ai': '#ef4444',
    'narrative-generation': '#f97316',
    'audio-perception': '#14b8a6',
    'model-intelligence': '#6366f1',
    'recommendation': '#d946ef',
    'system-intelligence': '#0ea5e9',
    'agent-interaction': '#64748b',
    'emergent-simulation': '#eab308'
  };

  const themeColors = {
    'autonomous-agents': '#3b82f6',
    'infrastructure-tooling': '#10b981',
    'human-machine-interface': '#8b5cf6',
    'emergent-systems': '#f59e0b',
    'generative-media': '#ec4899'
  };

  const statusColors = {
    'active': '#22c55e',
    'shipped': '#3b82f6',
    'early': '#eab308',
    'dormant': '#52525b'
  };

  let currentLens = 'domain';

  function getColor(node) {
    if (currentLens === 'domain') return domainColors[node.domain] || '#64748b';
    if (currentLens === 'theme') return themeColors[node.themes[0]] || '#64748b';
    if (currentLens === 'status') return statusColors[node.status] || '#64748b';
    return '#64748b';
  }

  // Build SVG with D3
  const ns = 'http://www.w3.org/2000/svg';
  const svg = document.createElementNS(ns, 'svg');
  svg.setAttribute('width', width);
  svg.setAttribute('height', height);
  svg.setAttribute('viewBox', `0 0 ${width} ${height}`);
  container.appendChild(svg);

  // Create elements
  const edgeGroup = document.createElementNS(ns, 'g');
  const nodeGroup = document.createElementNS(ns, 'g');
  const labelGroup = document.createElementNS(ns, 'g');
  svg.appendChild(edgeGroup);
  svg.appendChild(nodeGroup);
  svg.appendChild(labelGroup);

  const nodes = data.nodes.map(n => ({ ...n }));
  const edges = data.edges.map(e => ({
    source: nodes.find(n => n.id === e.source),
    target: nodes.find(n => n.id === e.target),
    type: e.type,
    label: e.label
  }));

  // Draw edges
  const lines = edges.map(e => {
    const line = document.createElementNS(ns, 'line');
    line.setAttribute('stroke', e.type === 'lineage' ? '#3f3f46' : '#27272a');
    line.setAttribute('stroke-width', e.type === 'lineage' ? '1.5' : '1');
    line.setAttribute('stroke-dasharray', e.type === 'theme' ? '4 4' : 'none');
    line.setAttribute('stroke-opacity', '0.6');
    edgeGroup.appendChild(line);
    return { el: line, data: e };
  });

  // Draw nodes
  const circles = nodes.map(n => {
    const circle = document.createElementNS(ns, 'circle');
    const r = n.featured ? 14 : 8;
    circle.setAttribute('r', r);
    circle.setAttribute('fill', getColor(n));
    circle.setAttribute('stroke', '#09090b');
    circle.setAttribute('stroke-width', '2');
    circle.style.cursor = 'pointer';
    circle.setAttribute('data-id', n.id);
    nodeGroup.appendChild(circle);

    circle.addEventListener('mouseenter', (ev) => {
      tooltip.innerHTML = `<strong>${n.name}</strong><br/><span style="color:#a1a1aa">${n.domain}</span>`;
      tooltip.classList.remove('hidden');
      tooltip.style.left = (ev.clientX - container.getBoundingClientRect().left + 12) + 'px';
      tooltip.style.top = (ev.clientY - container.getBoundingClientRect().top - 40) + 'px';
    });
    circle.addEventListener('mouseleave', () => tooltip.classList.add('hidden'));
    circle.addEventListener('click', () => {
      window.location.href = `/projects/${n.id}/`;
    });

    return { el: circle, data: n, r };
  });

  // Draw labels
  const labels = nodes.map(n => {
    const text = document.createElementNS(ns, 'text');
    text.textContent = n.name;
    text.setAttribute('fill', '#a1a1aa');
    text.setAttribute('font-size', n.featured ? '11' : '9');
    text.setAttribute('font-family', 'var(--font-mono)');
    text.setAttribute('text-anchor', 'middle');
    text.setAttribute('pointer-events', 'none');
    labelGroup.appendChild(text);
    return { el: text, data: n };
  });

  // Force simulation (vanilla, no D3 import needed at runtime)
  const centerX = width / 2;
  const centerY = height / 2;

  // Initialize positions in a circle
  nodes.forEach((n, i) => {
    const angle = (2 * Math.PI * i) / nodes.length;
    const spread = Math.min(width, height) * 0.3;
    n.x = centerX + Math.cos(angle) * spread;
    n.y = centerY + Math.sin(angle) * spread;
    n.vx = 0;
    n.vy = 0;
  });

  function simulate() {
    const alpha = 0.3;

    // Center gravity
    nodes.forEach(n => {
      n.vx += (centerX - n.x) * 0.01;
      n.vy += (centerY - n.y) * 0.01;
    });

    // Edge attraction
    edges.forEach(e => {
      const dx = e.target.x - e.source.x;
      const dy = e.target.y - e.source.y;
      const dist = Math.sqrt(dx * dx + dy * dy) || 1;
      const targetDist = 120;
      const force = (dist - targetDist) * 0.005;
      e.source.vx += dx / dist * force;
      e.source.vy += dy / dist * force;
      e.target.vx -= dx / dist * force;
      e.target.vy -= dy / dist * force;
    });

    // Node repulsion
    for (let i = 0; i < nodes.length; i++) {
      for (let j = i + 1; j < nodes.length; j++) {
        const dx = nodes[j].x - nodes[i].x;
        const dy = nodes[j].y - nodes[i].y;
        const dist = Math.sqrt(dx * dx + dy * dy) || 1;
        const minDist = 70;
        if (dist < minDist) {
          const force = (minDist - dist) / dist * 0.5;
          nodes[i].vx -= dx * force;
          nodes[i].vy -= dy * force;
          nodes[j].vx += dx * force;
          nodes[j].vy += dy * force;
        }
      }
    }

    // Apply velocity with damping
    const padding = 30;
    nodes.forEach(n => {
      n.vx *= 0.6;
      n.vy *= 0.6;
      n.x += n.vx * alpha;
      n.y += n.vy * alpha;
      n.x = Math.max(padding, Math.min(width - padding, n.x));
      n.y = Math.max(padding, Math.min(height - padding, n.y));
    });

    // Update DOM
    lines.forEach(l => {
      l.el.setAttribute('x1', l.data.source.x);
      l.el.setAttribute('y1', l.data.source.y);
      l.el.setAttribute('x2', l.data.target.x);
      l.el.setAttribute('y2', l.data.target.y);
    });
    circles.forEach(c => {
      c.el.setAttribute('cx', c.data.x);
      c.el.setAttribute('cy', c.data.y);
    });
    labels.forEach(l => {
      const r = l.data.featured ? 14 : 8;
      l.el.setAttribute('x', l.data.x);
      l.el.setAttribute('y', l.data.y + r + 14);
    });
  }

  // Run simulation
  let frame = 0;
  function tick() {
    simulate();
    frame++;
    if (frame < 200) requestAnimationFrame(tick);
  }
  tick();

  // Lens switching
  function updateColors() {
    circles.forEach(c => {
      c.el.setAttribute('fill', getColor(c.data));
    });
  }

  document.querySelectorAll('.lens-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.lens-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      currentLens = btn.getAttribute('data-lens');
      updateColors();
    });
  });
})();
</script>

<style>
  .lens-btn.active {
    border-color: var(--color-accent);
    color: var(--color-text);
  }
</style>
