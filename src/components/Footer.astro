---
const brand = import.meta.env.INTERSITE_FOOTER_BRAND || 'Portfolio';
const email = import.meta.env.INTERSITE_CONTACT_EMAIL;
---
<footer class="border-t border-[var(--color-border)] mt-24 px-6 py-8">
  <div class="max-w-5xl mx-auto flex justify-between items-center text-sm text-[var(--color-text-muted)]">
    <span class="font-mono">{brand}</span>
    {email && (
      <a href={`mailto:${email}`} class="hover:text-[var(--color-text)]">Contact</a>
    )}
  </div>
</footer>
