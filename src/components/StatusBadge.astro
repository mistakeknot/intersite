---
interface Props {
  status: "active" | "shipped" | "dormant" | "early";
}
const { status } = Astro.props;
const colors = {
  active: "bg-green-900/30 text-green-400",
  shipped: "bg-blue-900/30 text-blue-400",
  dormant: "bg-zinc-800 text-zinc-500",
  early: "bg-yellow-900/30 text-yellow-400",
};
---
<span class={`text-xs font-mono px-2 py-0.5 rounded ${colors[status]}`}>{status}</span>
