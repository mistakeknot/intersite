---
import Base from '../../../layouts/Base.astro';
import { getAllPlugins } from '../../../lib/content';

const plugins = await getAllPlugins();
const pillars = [
  { name: "Intercore", layer: "L1", desc: "Kernel — shared infrastructure" },
  { name: "Intermute", layer: "L1", desc: "Kernel — inter-agent communication" },
  { name: "Clavain", layer: "L2", desc: "OS — development orchestration" },
  { name: "Skaffen", layer: "L2", desc: "Sovereign agent intelligence" },
  { name: "Autarch", layer: "L3", desc: "Factory dashboard application" },
  { name: "Intercom", layer: "L3", desc: "Communication hub application" },
];
---
<Base title="Sylveste" description="Autonomous software development agency platform — 6 pillars, 3 layers">
  <div class="mb-8">
    <a href="/projects/" class="text-sm text-[var(--color-text-muted)] hover:text-[var(--color-text)] font-mono">&larr; Projects</a>
  </div>

  <header class="mb-12">
    <h1 class="text-2xl font-light mb-2">Sylveste</h1>
    <p class="text-[var(--color-text-muted)]">Autonomous software development agency platform. 6 pillars across 3 layers: kernel, OS, applications.</p>
  </header>

  <section class="mb-12">
    <h2 class="text-sm font-mono text-[var(--color-text-muted)] uppercase tracking-wider mb-6">Pillars</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      {pillars.map((p) => (
        <div class="border border-[var(--color-border)] rounded-lg p-4">
          <div class="flex items-center gap-2 mb-1">
            <h3 class="font-medium text-sm">{p.name}</h3>
            <span class="text-xs font-mono px-2 py-0.5 rounded bg-[var(--color-surface)] text-[var(--color-text-muted)]">{p.layer}</span>
          </div>
          <p class="text-[var(--color-text-muted)] text-xs">{p.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <section>
    <h2 class="text-sm font-mono text-[var(--color-text-muted)] uppercase tracking-wider mb-6">
      <a href="/projects/sylveste/plugins/" class="hover:text-[var(--color-text)]">
        Interverse Plugins ({plugins.length})
      </a>
    </h2>
    <p class="text-[var(--color-text-muted)] text-sm">
      The plugin ecosystem powering Sylveste's extensibility.
      <a href="/projects/sylveste/plugins/" class="text-[var(--color-accent)] hover:underline">Browse all &rarr;</a>
    </p>
  </section>
</Base>
